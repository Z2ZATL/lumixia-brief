# Runtime
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173
PORT=8787

# Local demo only. Production startup rejects these values.
LOCAL_AUTH_BYPASS=true
PROVIDER_MODE=mock
DATA_MODE=memory

# Clerk: enable Google only, require TOTP + backup codes, and activate the native Supabase integration.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase project (use separate staging and production projects)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Notion public OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:5173/api/notion/callback

# Generate separately for each environment:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
# At least 32 random characters
OAUTH_STATE_SECRET=

# Error monitoring; Session Replay must remain disabled in Sentry.
SENTRY_DSN=
VITE_SENTRY_DSN=
