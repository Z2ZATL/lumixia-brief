# Runtime
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173
PORT=8787

# Local demo only. Production startup rejects these values.
AUTH_MODE=local-demo
VITE_AUTH_MODE=local-demo
MODEL_PROVIDER_MODE=mock
NOTION_PROVIDER_MODE=mock
DATA_MODE=memory
CODEX_MCP_MODE=enabled
# Owner-operated video-demo bridge. The Codex process remains on localhost.
CODEX_LOCAL_BRIDGE_MODE=enabled

# Supabase Auth + database (use separate staging and production projects).
# These values are public project identifiers; never add a service-role key to application runtime.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Notion public OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:5173/notion/callback

# Generate separately for each environment:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
# At least 32 random characters
OAUTH_STATE_SECRET=

# Error monitoring; Session Replay must remain disabled in Sentry.
SENTRY_DSN=
VITE_SENTRY_DSN=
